1) % GRAD_ACCUM == 0:\n            scaler.unscale_(optimizer)\n            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n            scaler.step(optimizer)\n            scaler.update()\n            scheduler.step()\n            optimizer.zero_grad()\n            _global_step += 1\n            if USE_WANDB:\n                wandb.log({'train/step_loss': loss.item() * GRAD_ACCUM,\n                           'train/lr': scheduler.get_last_lr()[0]},\n                          step=_global_step)\n\n        total_loss += loss.item() * GRAD_ACCUM\n        preds = torch.argmax(logits, dim=1)\n        f1_metric.update(preds, labels)\n\n    return total_loss / len(loader), f1_metric.compute().item()\n\n\ndef validate(model, loader):\n    model.eval()\n    f1_metric.reset()\n    with torch.no_grad():\n        for images, labels in tqdm(loader, desc='Validation'):\n            images = images.to(DEVICE)\n            labels = labels.to(DEVICE)\n            with autocast(enabled=(DEVICE == 'cuda')):\n                logits = model(images)\n            preds = torch.argmax(logits, dim=1)\n            f1_metric.update(preds, labels)\n    return f1_metric.compute().item()\n\n\nprint('train_one_epoch and validate ready!')","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["train_one_epoch and validate ready!\n"]}],"execution_count":16},{"id":"165e8fcc-a300-42a6-a36c-da9619bb4d81","cell_type":"markdown","source":"## Cell 21 — Phase 1: Head Warmup\n\nFreeze `conv1 + bn1 + layer1 + layer2 + layer3`. Only `layer4` and the custom `fc`\nhead are trainable. This lets the randomly-initialised head stabilise before any\npretrained weights are updated.\n\n`OneCycleLR` with `pct_start=0.1` warms up for 10% of total steps then cosine-anneals.","metadata":{}},{"id":"ce80bedb-6990-4ead-98f5-d676ffea0ed5","cell_type":"code","source":"# ── CELL 21: PHASE 1 — Head Warmup ─────────────────────\nfrozen_p1 = [model.conv1, model.bn1, model.layer1, model.layer2, model.lay